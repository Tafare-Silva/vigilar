# ─────────────────────────────────────────────
# Django
# ─────────────────────────────────────────────
DJANGO_SECRET_KEY=troque-por-uma-chave-segura-de-50-caracteres-ou-mais
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=seudominio.com.br,www.seudominio.com.br

# ─────────────────────────────────────────────
# Banco de dados (PostgreSQL)
# ─────────────────────────────────────────────
DB_NAME=vigilar_db
DB_USER=vigilar_user
DB_PASSWORD=senha-forte-aqui
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=60

# ─────────────────────────────────────────────
# Redis / Celery
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# ─────────────────────────────────────────────
# E-mail (SMTP)
# ─────────────────────────────────────────────
EMAIL_HOST=smtp.seuservidor.com.br
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@seudominio.com.br
EMAIL_HOST_PASSWORD=senha-do-email
DEFAULT_FROM_EMAIL=noreply@seudominio.com.br
SERVER_EMAIL=noreply@seudominio.com.br

# ─────────────────────────────────────────────
# Sentry (monitoramento de erros — opcional)
# ─────────────────────────────────────────────
SENTRY_DSN=

# ─────────────────────────────────────────────
# Dados da empresa
# ─────────────────────────────────────────────
NOME_EMPRESA=C.R.S Segurança
CNPJ_EMPRESA=00.000.000/0001-00
TELEFONE_EMPRESA=(00) 00000-0000
